# Newfoot local config. Copy to .env (init.sh does this automatically).
# POC-only local credentials — do NOT reuse for anything real.

# Database
DB_NAME=newfoot
DB_USER=newfoot
DB_PASSWORD=newfoot
MYSQL_ROOT_PASSWORD=rootpw

# Host port mappings (change if something already uses these locally)
FRONTEND_HOST_PORT=4200
BACKEND_HOST_PORT=3000
DB_HOST_PORT=3307

# Runtime
NODE_ENV=development
LOG_LEVEL=info
