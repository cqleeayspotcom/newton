# Newfoot local config. Copy to .env (init.sh does this automatically).
# POC-only local credentials — do NOT reuse for anything real.

# Database
DB_NAME=newfoot
DB_USER=newfoot
DB_PASSWORD=newfoot
MYSQL_ROOT_PASSWORD=rootpw

# Host port mappings (change if something already uses these locally)
FRONTEND_HOST_PORT=4200
BACKEND_HOST_PORT=3000
DB_HOST_PORT=3307

# Runtime
NODE_ENV=development
LOG_LEVEL=info

# --- Sponsor integrations (server-side only; needed once F166+ are built) ---
# Akash AkashML — LLM brain for the Concierge agent + chatbot (OpenAI-compatible).
# Get a key at https://akashml.com (paid; trial credits). Leave blank until F166.
AKASHML_API_KEY=
AKASHML_BASE_URL=https://api.akashml.com/v1
AKASHML_MODEL=meta-llama/Llama-3.3-70B-Instruct
# Zero.xyz — the agent's real-time web tools. Leave blank until F167.
ZERO_API_KEY=
# Ghost (Postgres for AI agents) — agent memory/state. Leave blank until F168.
GHOST_DATABASE_URL=
