# Newfoot local config. Copy to .env (init.sh does this automatically).
# POC-only local credentials — do NOT reuse for anything real.

# Database
DB_NAME=newfoot
DB_USER=newfoot
DB_PASSWORD=newfoot
MYSQL_ROOT_PASSWORD=rootpw

# Host port mappings (change if something already uses these locally)
FRONTEND_HOST_PORT=4200
BACKEND_HOST_PORT=3000
DB_HOST_PORT=3307

# Runtime
NODE_ENV=development
LOG_LEVEL=info

# --- Sponsor integrations ---
# 3 sponsor tools = Akash + Zero + Pomerium (see docs/decisions.md ADR-0014):
#   - Zero.xyz    : NO key. Uses the `zero` CLI (zero init; zero auth agent register).
#                   Fund the wallet only for PAID capabilities (`zero wallet fund`).
#   - Pomerium    : NO key. Open-source proxy configured via pomerium/config.yaml.
#   - Akash deploy: CONSOLE_API_KEY (set above) via console-axi.
# Only the LLM brain still needs a key:
# Akash AkashML — LLM brain for the Concierge agent + chatbot (OpenAI-compatible).
# Get a key at https://akashml.com (paid; trial credits). Leave blank until F166.
AKASHML_API_KEY=
AKASHML_BASE_URL=https://api.akashml.com/v1
AKASHML_MODEL=meta-llama/Llama-3.3-70B-Instruct
